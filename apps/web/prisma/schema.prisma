generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) required models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  timeLimits TimeLimit[]
  usageLogs  UsageLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// App models
// ---------------------------------------------------------------------------

// A per-domain blocking rule owned by a user. dailyLimit is the maximum
// minutes per day the user may spend on the domain; null = always blocked.
model TimeLimit {
  id         String   @id @default(cuid())
  userId     String
  domain     String
  dailyLimit Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules Schedule[]
  usageLogs UsageLog[]

  @@unique([userId, domain])
}

// Time-of-day windows during which a TimeLimit is enforced.
model Schedule {
  id          String   @id @default(cuid())
  timeLimitId String
  startTime   String   // HH:MM (24-hour)
  endTime     String   // HH:MM (24-hour)
  daysOfWeek  Int[]    // 0 = Sunday … 6 = Saturday
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeLimit TimeLimit @relation(fields: [timeLimitId], references: [id], onDelete: Cascade)
}

// One record per browsing session on a tracked domain.
model UsageLog {
  id          String    @id @default(cuid())
  userId      String
  timeLimitId String?
  domain      String
  duration    Int       // seconds spent during this session
  blockedAt   DateTime?
  loggedAt    DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeLimit TimeLimit? @relation(fields: [timeLimitId], references: [id], onDelete: SetNull)
}